---
interface Props {
  level: number;
  title: string;
  description: string;
  lessons: number;
  href: string;
}

const { level, title, description, lessons, href } = Astro.props;
const isEN = Astro.url.pathname.includes('/en/');
const lessonsLabel = isEN ? `${lessons} lessons` : `${lessons} Lektionen`;
---

<a href={href} class={`level-card level-card--l${level}`}>
  <div class="level-card__header">
    <span class={`level-card__badge level-card__badge--l${level}`}>{level}</span>
    <span class="level-card__title">{title}</span>
  </div>
  <p class="level-card__description">{description}</p>
  <span class="level-card__meta">{lessonsLabel}</span>
</a>

<style>
  .level-card {
    display: block;
    background: var(--af-surface);
    border-radius: 10px;
    padding: 1.25rem;
    border-left: 3px solid transparent;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .level-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transform: translateY(-1px);
    text-decoration: none;
    color: inherit;
  }

  .level-card--l1 { border-left-color: var(--af-l1); }
  .level-card--l2 { border-left-color: var(--af-l2); }
  .level-card--l3 { border-left-color: var(--af-l3); }
  .level-card--l4 { border-left-color: var(--af-l4); }

  .level-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .level-card__badge {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .level-card__badge--l1 { background: var(--af-l1-bg); color: var(--af-l1); }
  .level-card__badge--l2 { background: var(--af-l2-bg); color: var(--af-l2); }
  .level-card__badge--l3 { background: var(--af-l3-bg); color: var(--af-l3); }
  .level-card__badge--l4 { background: var(--af-l4-bg); color: var(--af-l4); }

  .level-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--af-text);
  }

  .level-card__description {
    font-size: 0.875rem;
    color: var(--af-text-secondary);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .level-card__meta {
    font-size: 0.75rem;
    color: var(--af-text-secondary);
    opacity: 0.7;
  }
</style>
